# Google Gemini — obtén tu key en https://aistudio.google.com/apikey
GEMINI_API_KEY=tu-api-key-aqui

# Twilio — dejar vacío (usamos el bridge gratuito whatsapp-web.js)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Base de datos (SQLite por defecto, cambia a PostgreSQL en producción)
DATABASE_URL=sqlite:///./beauty_scheduler.db

# Configuración del negocio
BUSINESS_NAME=Mi Estética
BUSINESS_PHONE=+34600000000
BUSINESS_TIMEZONE=Europe/Madrid

# Horario de atención (formato HH:MM)
BUSINESS_OPEN_TIME=09:00
BUSINESS_CLOSE_TIME=20:00
# Días laborales: 0=Lun, 1=Mar, 2=Mié, 3=Jue, 4=Vie, 5=Sáb, 6=Dom
BUSINESS_WORKING_DAYS=0,1,2,3,4,5,6

# Bridge Node.js (whatsapp-web.js)
BRIDGE_URL=http://localhost:3000
PYTHON_URL=http://localhost:8001

# Modo test: solo responde a estos números (vacío = responde a todos)
ALLOWED_PHONES=

# Recordatorios (horas antes de la cita)
REMINDER_HOURS_BEFORE=24

# Panel de administración (abre http://localhost:8001/admin)
ADMIN_PASSWORD=admin1234
ADMIN_SECRET=cambia-este-secreto-en-produccion
CALENDAR_KEY=cambia-esta-key-en-produccion

# Servidor
APP_HOST=0.0.0.0
APP_PORT=8001
